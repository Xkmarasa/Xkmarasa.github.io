# Connection string de tu base de datos Neon
# Formato: postgresql://usuario:password@host/neondb?sslmode=require
DATABASE_URL=postgresql://neondb_owner:TU_PASSWORD@ep-orange-heart-adbyxiqq-pooler.c-2.us-east-1.aws.neon.tech/neondb?sslmode=require

# Puerto del servidor (opcional, por defecto 3000)
# PORT=3000

# Entorno (development para local, production para Render)
# NODE_ENV=development

